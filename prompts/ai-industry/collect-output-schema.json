{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIIndustryFetchResult",
  "type": "object",
  "required": ["report_title", "report_date", "time_window_hours", "groups"],
  "properties": {
    "report_title": {
      "type": "string",
      "const": "AI行业情报"
    },
    "report_date": {
      "type": "string",
      "description": "报告生成日期，格式 YYYY-MM-DD"
    },
    "time_window_hours": {
      "type": "integer",
      "const": 48
    },
    "generated_at": {
      "type": "string",
      "description": "可选，ISO 8601 时间戳"
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["category", "summary", "items"],
        "properties": {
          "category": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "title",
                "published_at",
                "source_name",
                "source_url",
                "subject",
                "classification",
                "event_summary",
                "why_it_matters",
                "confidence",
                "related_focus",
                "within_48h",
                "status"
              ],
              "properties": {
                "title": { "type": "string" },
                "published_at": { "type": "string" },
                "source_name": { "type": "string" },
                "source_url": { "type": "string" },
                "subject": { "type": "string" },
                "classification": {
                  "type": "string",
                  "enum": [
                    "AI Agent",
                    "AI Coding",
                    "模型与基础设施",
                    "政策与监管",
                    "社区热点"
                  ]
                },
                "event_summary": { "type": "string" },
                "why_it_matters": { "type": "string" },
                "confidence": {
                  "type": "string",
                  "enum": ["high", "medium", "low"]
                },
                "related_focus": {
                  "oneOf": [
                    { "type": "string" },
                    {
                      "type": "array",
                      "items": { "type": "string" },
                      "minItems": 1
                    }
                  ]
                },
                "within_48h": { "type": "boolean" },
                "status": {
                  "type": "string",
                  "enum": ["confirmed", "tentative"]
                },
                "notes": { "type": "string" },
                "source_tier": {
                  "type": "string",
                  "enum": ["tier1", "tier2", "tier3", "P0", "P1", "P2", "P3"]
                },
                "supporting_sources": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["label", "url", "kind"],
                    "properties": {
                      "label": { "type": "string" },
                      "url": { "type": "string" },
                      "kind": {
                        "type": "string",
                        "enum": ["official", "media", "community", "podcast", "transcript"]
                      },
                      "note": { "type": "string" }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
