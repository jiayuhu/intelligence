# AI行业情报系统环境变量配置

# ==========================================
# 邮件发送配置 (AgentMail)
# ==========================================
AI_INDUSTRY_AGENTMAIL_API_KEY=
AI_INDUSTRY_AGENTMAIL_INBOX_ID=
AI_INDUSTRY_AGENTMAIL_BASE_URL=https://api.agentmail.to

# 收件人和发件人
AI_INDUSTRY_EMAIL_TO=recipient@example.com
AI_INDUSTRY_EMAIL_FROM=sender@example.com

# ==========================================
# SMTP 配置 (可选，与 AgentMail 二选一)
# ==========================================
# AI_INDUSTRY_SMTP_HOST=smtp.example.com
# AI_INDUSTRY_SMTP_PORT=587
# AI_INDUSTRY_SMTP_SECURE=false
# AI_INDUSTRY_SMTP_STARTTLS=true
# AI_INDUSTRY_SMTP_USER=your-account@example.com
# AI_INDUSTRY_SMTP_PASS=your-password
# AI_INDUSTRY_SMTP_HELO=localhost

# ==========================================
# Google Search API 配置 (全自动抓取)
# ==========================================
# 获取方式:
# 1. 访问 https://developers.google.com/custom-search/v1/overview
# 2. 点击 "Get a Key" 创建 API Key
# 3. 访问 https://cse.google.com/cse/ 创建 Custom Search Engine
# 4. 在 CSE 控制面板中获取 Search Engine ID
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
