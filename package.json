{
  "name": "intelligence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/generate-report.ts",
    "generate:prompt": "tsx scripts/generate-prompt.ts",
    "generate:send-prompt": "tsx scripts/generate-send-prompt.ts",
    "generate:fetch": "tsx scripts/generate-fetch.ts",
    "generate:md": "tsx scripts/generate-md.ts",
    "generate:send-output": "tsx scripts/generate-send-output.ts",
    "generate:report": "tsx scripts/generate-report.ts",
    "export:pdf": "tsx scripts/export-pdf.ts",
    "render:email": "tsx scripts/send-html-email.ts",
    "send:email": "tsx scripts/send-email.ts",
    "validate:ai-industry-samples": "tsx scripts/validate-ai-industry-samples.ts",
    "generate:all": "npm run generate:prompt && npm run generate:send-prompt && npm run fetch && npm run generate:md && npm run generate:send-output && npm run generate:report && npm run export:pdf && npm run render:email && npm run validate:ai-industry-samples && npm run send:email",
    "fetch:realtime": "tsx scripts/fetch-realtime.ts",
    "fetch:tasks": "tsx scripts/fetch-realtime.ts --tasks",
    "fetch": "tsx scripts/fetch-intelligence.ts",
    "fetch:feeds": "tsx scripts/fetch-feeds.ts",
    "fetch:html": "tsx scripts/fetch-html.ts",
    "fetch:playwright": "tsx scripts/fetch-playwright.ts",
    "fetch:google": "tsx scripts/fetch-google-api.ts",
    "fetch:tavily": "tsx scripts/fetch-tavily.ts",
    "test:tavily": "tsx scripts/test-tavily.ts",
    "generate:auto": "npm run fetch:realtime && npm run generate:all",
    "generate:auto:google": "npm run fetch:google && npm run generate:all",
    "setup": "tsx scripts/setup-env.ts",
    "demo:intel-engine": "tsx scripts/demo-intel-engine.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@fontsource/noto-sans-sc": "^5.2.7",
    "@types/node": "^22.15.0",
    "@types/pdfkit": "^0.17.5",
    "@vitest/ui": "^4.1.2",
    "dotenv": "^17.4.1",
    "pdfkit": "^0.17.2",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "cheerio": "^1.2.0",
    "playwright": "^1.59.1",
    "rss-parser": "^3.13.0"
  }
}
